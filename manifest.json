{
  "name": "Kayros",
  "appDomain": "kayros.app.provable.dev",
  "icon": "logo.svg",
  "description": "Kayros notarization and record lookup for PrivacySafe apps.",
  "version": "0.1.8",
  "components": {
    "/index.html": {
      "runtime": "web-gui",
      "formFactor": [
        "desktop",
        "tablet"
      ],
      "capsRequested": {
        "appRPC": [
          "KayrosNotary"
        ],
        "storage": {
          "appFS": "default"
        },
        "logToPlatform": true
      },
      "windowOpts": {
        "width": 1120,
        "height": 760,
        "minWidth": 920,
        "minHeight": 620
      }
    },
    "/service.html": {
      "runtime": "web-gui",
      "services": {
        "KayrosNotary": {
          "thisAppComponents": "*",
          "otherApps": [
            "files.app.privacysafe.io"
          ]
        }
      },
      "capsRequested": {
        "storage": {
          "appFS": "default"
        },
        "connectToExternal": {
          "fetch": [
            {
              "schema": "https",
              "domain": "kayros.provable.dev",
              "pathPrefix": "/api/"
            }
          ]
        },
        "logToPlatform": true
      },
      "windowOpts": {
        "width": 360,
        "height": 140,
        "minWidth": 360,
        "minHeight": 140,
        "resizable": false,
        "minimizable": false,
        "maximizable": false,
        "skipTaskbar": true,
        "frame": false
      }
    }
  },
  "launchers": [
    {
      "name": "Kayros",
      "icon": "logo.svg",
      "description": "Kayros notarization and record lookup for PrivacySafe apps.",
      "component": "/index.html",
      "formFactor": [
        "desktop",
        "tablet"
      ]
    }
  ]
}
