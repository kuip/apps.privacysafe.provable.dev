{
  "name": "Kayros",
  "appDomain": "kayros.app.provable.dev",
  "icon": "logo.svg",
  "description": "Kayros notarization and record lookup for PrivacySafe apps.",
  "version": "0.1.4",
  "components": {
    "/index.html": {
      "runtime": "web-gui",
      "services": {
        "KayrosNotary": {
          "thisAppComponents": "*",
          "otherApps": [
            "files.app.privacysafe.io"
          ]
        }
      },
      "formFactor": [
        "desktop",
        "tablet"
      ],
      "capsRequested": {
        "storage": {
          "appFS": "default"
        },
        "logToPlatform": true
      },
      "windowOpts": {
        "width": 1120,
        "height": 760,
        "minWidth": 920,
        "minHeight": 620
      }
    }
  },
  "launchers": [
    {
      "name": "Kayros",
      "icon": "logo.svg",
      "description": "Kayros notarization and record lookup for PrivacySafe apps.",
      "component": "/index.html",
      "formFactor": [
        "desktop",
        "tablet"
      ]
    }
  ]
}
